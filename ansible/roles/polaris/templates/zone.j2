$ORIGIN {{ zone }}.
$TTL 300
@   IN SOA ns hostmaster (
        {{ zone_serial | default(ansible_facts['date_time']['epoch']) }} ; serial
        3600    ; refresh
        600     ; retry
        86400   ; expire
        300 )   ; minimum
@   IN NS ns
ns  IN AAAA {{ polaris_address }}
{% for r in dns_zones[zone] %}
{% if r.AAAA is defined %}
{{ "%-18s"|format(r.name) }} IN AAAA {{ r.AAAA }}
{% endif %}
{% if r.A is defined %}
{{ "%-18s"|format(r.name) }} IN A    {{ r.A }}
{% endif %}
{% endfor %}
