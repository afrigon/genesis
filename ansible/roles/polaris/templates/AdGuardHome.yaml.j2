schema_version: 34
http:
  address: '[::]:3000'
users: []
dns:
  bind_hosts:
    - '::'
  port: 53
  # Filter-only now: single upstream is polaris-resolver. DNS64 and the .x/unifi
  # zones live downstream in the resolver/auth, not here.
  upstream_dns:
    - '[{{ polaris_resolver_address }}]:53'
  bootstrap_dns:
    - 2606:4700:4700::1111
    - 2001:4860:4860::8888
  upstream_mode: load_balance
  use_dns64: false
filters:
  - enabled: true
    url: https://adguardteam.github.io/AdGuardSDNSFilter/Filters/filter.txt
    name: AdGuard DNS filter
    id: 1
  - enabled: true
    url: https://big.oisd.nl
    name: OISD Big
    id: 2
filters_update_interval: 168
filtering:
  rewrites: []
